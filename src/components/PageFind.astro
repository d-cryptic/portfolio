---
import Search from "astro-pagefind/components/Search";
import { getCollection } from "astro:content";

const [blogPosts, projectPosts, notesPosts, snippetPosts] = await Promise.all([
  getCollection("blog", ({ data }) => !data.draft),
  getCollection("projects", ({ data }) => !data.draft),
  getCollection("notes", ({ data }) => !data.draft),
  getCollection("snippets", ({ data }) => !data.draft),
]);

const searchItems = [
  ...blogPosts.map((post) => ({
    title: post.data.title,
    description: post.data.description,
    url: `/blog/${post.id.replace(/\/index\.mdx?$/, "")}`,
    type: "blog",
    tags: post.data.tags || [],
    stack: post.data.stack || [],
    roles: post.data.roles || [],
    outcomes: post.data.outcomes || [],
    date: post.data.date.toISOString().slice(0, 10),
  })),
  ...projectPosts.map((project) => ({
    title: project.data.title,
    description: project.data.description,
    url: `/projects/${project.id}`,
    type: "projects",
    tags: project.data.tags || [],
    stack: project.data.stack || [],
    roles: project.data.roles || [],
    outcomes: project.data.outcomes || [],
    date: project.data.date.toISOString().slice(0, 10),
  })),
  ...notesPosts.map((note) => ({
    title: note.data.title,
    description: note.data.description,
    url: `/notes/${note.id}`,
    type: "notes",
    tags: note.data.tags || [],
    stack: note.data.stack || [],
    roles: note.data.roles || [],
    outcomes: note.data.outcomes || [],
    date: note.data.date.toISOString().slice(0, 10),
  })),
  ...snippetPosts.map((snippet) => ({
    title: snippet.data.title,
    description: snippet.data.description,
    url: `/snippets/${snippet.id}`,
    type: "snippets",
    tags: snippet.data.tags || [],
    stack: snippet.data.stack || [],
    roles: snippet.data.roles || [],
    outcomes: snippet.data.outcomes || [],
    date: snippet.data.date.toISOString().slice(0, 10),
  })),
  {
    title: "Content Explorer",
    description: "Filter content by stack, role, and outcome.",
    url: "/explorer",
    type: "pages",
    tags: ["explorer", "filters"],
    stack: ["astro"],
    roles: ["platform engineer"],
    outcomes: ["data", "seo"],
    date: "2025-11-01",
  },
  {
    title: "Tag Directory",
    description: "Browse all tags used across blog posts.",
    url: "/tags",
    type: "pages",
    tags: ["tags", "taxonomy"],
    stack: ["astro"],
    roles: ["software engineer"],
    outcomes: ["data"],
    date: "2025-11-01",
  },
  {
    title: "AI / Agent Guide",
    description: "Machine-friendly guide for assistants and agents.",
    url: "/for-ai",
    type: "pages",
    tags: ["ai", "agents"],
    stack: ["astro", "mdx"],
    roles: ["systems engineer"],
    outcomes: ["seo", "data"],
    date: "2025-11-01",
  },
];
---

<aside data-pagefind-ignore>
  <div
    id="backdrop"
    class="bg-[rgba(0, 0, 0, 0.5] invisible fixed top-0 left-0 z-50 flex h-screen w-full justify-center p-6 backdrop-blur-xs"
  >
    <div
      id="pagefind-container"
      class="m-0 flex h-fit max-h-[80%] w-full max-w-(--breakpoint-sm) flex-col overflow-auto rounded-sm border border-black/15 bg-[var(--color-background)] p-2 px-4 py-3 shadow-lg dark:border-white/20"
    >
      <Search
        id="search"
        className="pagefind-ui"
        uiOptions={{ showImages: false, excerptLength: 15, resetStyles: false }}
      />
      <div id="search-tips" class="pt-2 text-xs text-black/65 dark:text-white/65">
        Tip: <code>#tag</code> <code>@type</code> <code>type:</code> <code>tag:</code> <code>stack:</code> <code>role:</code> <code>outcome:</code> <code>since:</code> <code>until:</code> and exclusions with <code>-</code>
      </div>
      <div id="semantic-suggestions" class="mt-2 hidden"></div>
      <div class="dark:prose-invert mr-2 pt-4 pb-1 text-right text-xs">
        Press <span class="prose dark:prose-invert text-xs"
          ><kbd class="">Esc</kbd></span
        > or click anywhere to close
      </div>
    </div>
  </div>
</aside>

<script is:inline define:vars={{ searchItems }}>
  const semanticSearchItems = searchItems;

  const pagefindStylesheetId = "pagefind-ui-styles";
  const magnifyingGlass = document.getElementById("magnifying-glass");
  const backdrop = document.getElementById("backdrop");
  const suggestionsRoot = document.getElementById("semantic-suggestions");
  let semanticSearchInput = null;
  let semanticBindingsReady = false;
  let activeSuggestionIndex = -1;
  let currentSuggestions = [];

  const normalizeValue = (value) => value.toLowerCase().trim();
  const parseDate = (value) => {
    if (!value) return null;
    const timestamp = new Date(value).getTime();
    return Number.isNaN(timestamp) ? null : timestamp;
  };

  function tokenize(query) {
    const parsed = {
      include: { types: [], tags: [], stack: [], roles: [], outcomes: [], terms: [] },
      exclude: { types: [], tags: [], stack: [], roles: [], outcomes: [], terms: [] },
      since: "",
      until: "",
    };

    const tokens = query.trim().split(/\s+/).filter(Boolean);
    for (const raw of tokens) {
      const isNegative = raw.startsWith("-");
      const token = isNegative ? raw.slice(1) : raw;
      if (!token) continue;
      const target = isNegative ? parsed.exclude : parsed.include;
      const lowered = token.toLowerCase();

      if (lowered.startsWith("#")) {
        target.tags.push(normalizeValue(lowered.slice(1)));
        continue;
      }
      if (lowered.startsWith("@")) {
        target.types.push(normalizeType(normalizeValue(lowered.slice(1))));
        continue;
      }

      const separatorIndex = lowered.indexOf(":");
      if (separatorIndex !== -1) {
        const key = lowered.slice(0, separatorIndex);
        const value = normalizeValue(lowered.slice(separatorIndex + 1));
        if (!value) continue;
        if (key === "type") target.types.push(normalizeType(value));
        else if (key === "tag") target.tags.push(value);
        else if (key === "stack") target.stack.push(value);
        else if (key === "role") target.roles.push(value);
        else if (key === "outcome") target.outcomes.push(value);
        else if (key === "since" || key === "from") parsed.since = value;
        else if (key === "until" || key === "to") parsed.until = value;
        else target.terms.push(value);
        continue;
      }

      target.terms.push(lowered);
    }

    return parsed;
  }

  function normalizeType(type) {
    const aliases = {
      blog: "blog",
      blogs: "blog",
      project: "projects",
      projects: "projects",
      note: "notes",
      notes: "notes",
      snippet: "snippets",
      snippets: "snippets",
      page: "pages",
      pages: "pages",
      explorer: "pages",
    };
    return aliases[type] || type;
  }

  function fuzzyScore(text, query) {
    if (!query) return 0;
    const haystack = text.toLowerCase();
    const needle = query.toLowerCase();
    if (haystack.includes(needle)) {
      return 100 - haystack.indexOf(needle);
    }

    let score = 0;
    let searchIndex = 0;
    for (let i = 0; i < needle.length; i++) {
      const foundAt = haystack.indexOf(needle[i], searchIndex);
      if (foundAt === -1) {
        return -1;
      }
      score += 2;
      searchIndex = foundAt + 1;
    }
    return score;
  }

  function semanticSearch(query) {
    const { include, exclude, since, until } = tokenize(query);
    if (!query.trim()) {
      return [];
    }

    const sinceTs = parseDate(since);
    const untilTs = parseDate(until);

    return semanticSearchItems
      .filter((item) => {
        const itemType = normalizeType(normalizeValue(item.type || ""));
        const itemTags = (item.tags || []).map((tag) => normalizeValue(tag));
        const itemStack = (item.stack || []).map((value) => normalizeValue(value));
        const itemRoles = (item.roles || []).map((value) => normalizeValue(value));
        const itemOutcomes = (item.outcomes || []).map((value) => normalizeValue(value));
        const itemDate = parseDate(item.date);

        const matchesOrEmpty = (selected, values) =>
          selected.length === 0 || selected.some((value) => values.includes(value));
        const hasExcluded = (selected, values) =>
          selected.length > 0 && selected.some((value) => values.includes(value));

        if (!matchesOrEmpty(include.types, [itemType])) return false;
        if (!matchesOrEmpty(include.tags, itemTags)) return false;
        if (!matchesOrEmpty(include.stack, itemStack)) return false;
        if (!matchesOrEmpty(include.roles, itemRoles)) return false;
        if (!matchesOrEmpty(include.outcomes, itemOutcomes)) return false;
        if (hasExcluded(exclude.types, [itemType])) return false;
        if (hasExcluded(exclude.tags, itemTags)) return false;
        if (hasExcluded(exclude.stack, itemStack)) return false;
        if (hasExcluded(exclude.roles, itemRoles)) return false;
        if (hasExcluded(exclude.outcomes, itemOutcomes)) return false;

        if (sinceTs && itemDate && itemDate < sinceTs) return false;
        if (untilTs && itemDate && itemDate > untilTs) return false;

        const searchableText = [
          item.title,
          item.description,
          item.url,
          item.type,
          ...(item.tags || []),
          ...(item.stack || []),
          ...(item.roles || []),
          ...(item.outcomes || []),
        ].join(" ");

        const hasAllTerms = include.terms.every((term) => fuzzyScore(searchableText, term) >= 0);
        if (!hasAllTerms) {
          return false;
        }
        const hasExcludedTerm = exclude.terms.some((term) => fuzzyScore(searchableText, term) >= 0);
        if (hasExcludedTerm) {
          return false;
        }
        return true;
      })
      .map((item) => {
        const searchableText = [
          item.title,
          item.description,
          item.url,
          item.date,
          item.type,
          ...(item.tags || []),
          ...(item.stack || []),
          ...(item.roles || []),
          ...(item.outcomes || []),
        ].join(" ");

        const score =
          (include.terms.length > 0
            ? include.terms.reduce((sum, term) => sum + Math.max(0, fuzzyScore(searchableText, term)), 0)
            : 20) +
          include.tags.length * 20 +
          include.types.length * 20 +
          include.stack.length * 15 +
          include.roles.length * 15 +
          include.outcomes.length * 15;

        return { item, score };
      })
      .filter((entry) => entry.score >= 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 8);
  }

  function renderSemanticSuggestions(query, preserveActive = false) {
    if (!suggestionsRoot) {
      return;
    }

    const matches = semanticSearch(query);
    currentSuggestions = matches;
    if (!preserveActive) {
      activeSuggestionIndex = matches.length > 0 ? 0 : -1;
    } else if (matches.length === 0) {
      activeSuggestionIndex = -1;
    } else {
      activeSuggestionIndex = Math.min(
        Math.max(activeSuggestionIndex, 0),
        matches.length - 1,
      );
    }
    if (matches.length === 0) {
      suggestionsRoot.innerHTML = "";
      suggestionsRoot.classList.add("hidden");
      return;
    }

    suggestionsRoot.innerHTML = `
      <div class="semantic-suggestions-list">
        ${matches
          .map(
            ({ item }, index) => `
            <a class="semantic-suggestion-item ${index === activeSuggestionIndex ? "active" : ""}" href="${item.url}" data-suggestion-index="${index}">
              <div class="semantic-suggestion-title">${item.title}</div>
              <div class="semantic-suggestion-meta">
                <span>@${item.type}</span>
                <span>${item.date}</span>
                ${(item.tags || []).slice(0, 3).map((tag) => `<span>#${tag}</span>`).join("")}
              </div>
            </a>
          `,
          )
          .join("")}
      </div>
    `;
    suggestionsRoot.classList.remove("hidden");
  }

  function bindSemanticSearch() {
    const searchDiv = document.getElementById("search");
    if (!searchDiv) {
      return;
    }

    semanticSearchInput = searchDiv.querySelector("input");
    if (!semanticSearchInput) {
      return;
    }

    if (semanticBindingsReady) {
      return;
    }

    semanticSearchInput.addEventListener("input", (event) => {
      const value = event.target?.value || "";
      renderSemanticSuggestions(value);
    });

    semanticSearchInput.addEventListener("keydown", (event) => {
      if (currentSuggestions.length === 0) return;
      if (event.key === "ArrowDown") {
        event.preventDefault();
        activeSuggestionIndex = (activeSuggestionIndex + 1) % currentSuggestions.length;
        renderSemanticSuggestions(semanticSearchInput.value || "", true);
      } else if (event.key === "ArrowUp") {
        event.preventDefault();
        activeSuggestionIndex =
          (activeSuggestionIndex - 1 + currentSuggestions.length) % currentSuggestions.length;
        renderSemanticSuggestions(semanticSearchInput.value || "", true);
      } else if (event.key === "Enter") {
        event.preventDefault();
        const selected = currentSuggestions[activeSuggestionIndex];
        if (selected?.item?.url) {
          window.location.href = selected.item.url;
        }
      }
    });

    semanticSearchInput.addEventListener("focus", () => {
      renderSemanticSuggestions(semanticSearchInput.value || "");
    });

    semanticSearchInput.addEventListener("blur", () => {
      setTimeout(() => {
        suggestionsRoot?.classList.add("hidden");
      }, 120);
    });

    semanticBindingsReady = true;
  }

  function ensurePagefindStyles() {
    if (document.getElementById(pagefindStylesheetId)) {
      return Promise.resolve();
    }

    return new Promise((resolve) => {
      const stylesheet = document.createElement("link");
      stylesheet.id = pagefindStylesheetId;
      stylesheet.rel = "stylesheet";
      stylesheet.href = "/pagefind/pagefind-ui.css";
      stylesheet.onload = () => resolve();
      stylesheet.onerror = () => resolve();
      document.head.appendChild(stylesheet);
    });
  }

  async function openPagefind() {
    await ensurePagefindStyles();
    const searchDiv = document.getElementById("search");
    bindSemanticSearch();
    const search = searchDiv.querySelector("input");
    setTimeout(() => {
      search.focus();
    }, 0);
    backdrop?.classList.remove("invisible");
    backdrop?.classList.add("visible");
  }

  function closePagefind() {
    const search = document.getElementById("search");
    const input = search?.querySelector("input");
    if (input) {
      input.value = "";
      input.dispatchEvent(new Event("input", { bubbles: true }));
    }
    backdrop?.classList.remove("visible");
    backdrop?.classList.add("invisible");
    suggestionsRoot?.classList.add("hidden");
  }

  if (!window.__pagefindListenersBound) {
    // open pagefind
    magnifyingGlass?.addEventListener("click", () => {
      openPagefind();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "/") {
        e.preventDefault();
        openPagefind();
      } else if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        openPagefind();
      }
    });

    // close pagefind
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        closePagefind();
      }
    });

    // close pagefind when searched result(link) clicked
    document.addEventListener("click", (event) => {
      if (
        event.target instanceof Element &&
        event.target.classList.contains("pagefind-ui__result-link")
      ) {
        closePagefind();
      }
      if (
        event.target instanceof Element &&
        event.target.closest(".semantic-suggestion-item")
      ) {
        closePagefind();
      }
    });

    backdrop?.addEventListener("click", (event) => {
      if (!event.target.closest("#pagefind-container")) {
        closePagefind();
      }
    });

    // prevent form submission
    const form = document.getElementById("form");
    form?.addEventListener("submit", (event) => {
      event.preventDefault();
    });

    window.__pagefindListenersBound = true;
  }
</script>

<style is:global>
  :root {
    --pagefind-ui-scale: 0.75;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 3px;
    --pagefind-ui-font: var(--font-sans);
    --pagefind-ui-primary: var(--color-text);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-background);
    --pagefind-ui-border: var(--color-muted);
    --pagefind-ui-tag: var(--color-highlight);
  }

  .dark {
    --pagefind-ui-primary: #f1f5ff;
    --pagefind-ui-text: #e2e8ff;
    --pagefind-ui-background: #171a2e;
    --pagefind-ui-border: #3e476e;
    --pagefind-ui-tag: #28315e;
  }

  .dark #pagefind-container {
    background-color: #14182d;
    border-color: #4a537f;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.45);
  }

  #search input {
    font-weight: 500;
  }

  #pagefind-container,
  #search,
  #search .pagefind-ui__result,
  #search .pagefind-ui__result-title,
  #search .pagefind-ui__result-excerpt,
  #search .pagefind-ui__message,
  #search .pagefind-ui__search-input,
  #search-tips,
  .semantic-suggestions-list,
  .semantic-suggestion-item {
    font-family: var(--font-sans);
  }

  #search p,
  #search .pagefind-ui__message,
  #search .pagefind-ui__result-excerpt {
    color: var(--pagefind-ui-text);
    opacity: 0.95;
  }

  #search .pagefind-ui__result-title {
    font-weight: 700;
    line-height: 1.4;
  }

  #search .pagefind-ui__result-title a {
    color: var(--pagefind-ui-primary);
    text-decoration: none;
  }

  #search .pagefind-ui__result-title a:hover,
  #search .pagefind-ui__result-title a:focus-visible {
    color: #ffffff;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  #search .pagefind-ui__message {
    padding: 0;
    padding-bottom: 0.75rem;
  }

  #search .pagefind-ui__results {
    border-top: 1px solid color-mix(in srgb, var(--pagefind-ui-border) 70%, transparent);
    margin-top: 0.5rem;
  }

  #search .pagefind-ui__result {
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
    border-bottom-color: color-mix(in srgb, var(--pagefind-ui-border) 70%, transparent);
  }

  #search mark {
    background: #ffe454;
    color: #111111;
    border-radius: 2px;
    padding: 0 0.15rem;
  }

  .dark #search mark {
    background: #ffe95a;
    color: #0c1020;
  }

  #search-tips kbd {
    border: 1px solid var(--pagefind-ui-border);
    border-radius: 4px;
    padding: 0.1rem 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--pagefind-ui-primary);
    background: color-mix(in srgb, var(--pagefind-ui-tag) 40%, transparent);
  }

  #search-tips code {
    color: var(--pagefind-ui-primary);
    background: color-mix(in srgb, var(--pagefind-ui-tag) 35%, transparent);
    border: 1px solid color-mix(in srgb, var(--pagefind-ui-border) 50%, transparent);
    border-radius: 4px;
    padding: 0.08rem 0.3rem;
    font-size: 0.72rem;
    margin-right: 0.12rem;
  }

  .semantic-suggestions-list {
    border: 1px solid var(--pagefind-ui-border);
    border-radius: 6px;
    overflow: hidden;
    background-color: color-mix(in srgb, var(--pagefind-ui-background) 85%, #000 15%);
  }

  .semantic-suggestion-item {
    display: block;
    padding: 0.5rem 0.625rem;
    border-bottom: 1px solid var(--pagefind-ui-border);
    text-decoration: none;
    color: var(--pagefind-ui-text);
    transition: background-color 0.15s ease-in-out;
  }

  .semantic-suggestion-item:last-child {
    border-bottom: none;
  }

  .semantic-suggestion-item:hover {
    background-color: color-mix(in srgb, var(--pagefind-ui-border) 20%, transparent);
  }

  .semantic-suggestion-item.active {
    background-color: color-mix(in srgb, var(--pagefind-ui-border) 25%, transparent);
  }

  .semantic-suggestion-title {
    font-size: 0.875rem;
    font-weight: 600;
  }

  .semantic-suggestion-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.2rem;
    font-size: 0.75rem;
    opacity: 0.9;
  }
</style>
