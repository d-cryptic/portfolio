---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import { BLOG } from "@consts";
import { breadcrumbJsonLd, toAbsoluteUrl } from "@lib/seo";
import { isLocalBlogPost, normalizeSeriesKey } from "@lib/blog-series";
import { shouldIncludeDraftContent } from "@lib/content-visibility";

// Get all blog posts
const allBlogPosts = await getCollection("blog", ({ data }) =>
  shouldIncludeDraftContent(data.draft),
);

// Sort all posts by date (newest first)
const sortedPosts = allBlogPosts
  .map(post => ({
    ...post,
    data: {
      ...post.data,
      // Add any additional processing here if needed
    }
  }))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const seenSeries = new Set<string>();
const seriesCounts = sortedPosts.reduce((acc: Record<string, number>, post) => {
  if (!isLocalBlogPost(post) || !post.data.series) {
    return acc;
  }

  const seriesKey = normalizeSeriesKey(post.data.series);
  if (!seriesKey) {
    return acc;
  }

  acc[seriesKey] = (acc[seriesKey] ?? 0) + 1;
  return acc;
}, {});

const dedupedPosts = sortedPosts.filter((post) => {
  if (!isLocalBlogPost(post) || !post.data.series) {
    return true;
  }

  const seriesKey = normalizeSeriesKey(post.data.series);
  if (!seriesKey) {
    return true;
  }

  if (seenSeries.has(seriesKey)) {
    return false;
  }

  seenSeries.add(seriesKey);
  return true;
});

// Group by year
const postsByYear = dedupedPosts.reduce((acc: { [key: string]: typeof dedupedPosts }, post) => {
  const year = post.data.date.getFullYear().toString();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push({
    ...post,
    // Add any additional properties needed by ArrowCard
  });
  return acc;
}, {});

const years = Object.keys(postsByYear).sort((a, b) => parseInt(b) - parseInt(a));
---

<Layout
  title={BLOG.TITLE}
  description={BLOG.DESCRIPTION}
  keywords={["SRE blog", "platform engineering", "systems posts", "DevOps articles"]}
  schema={[
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Blog", path: "/blog" },
    ]),
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      name: BLOG.TITLE,
      description: BLOG.DESCRIPTION,
      url: toAbsoluteUrl("/blog"),
    },
  ]}
>
  <Container>
    <aside data-pagefind-ignore>
      <div class="space-y-10">
        <div class="space-y-4">
          {
            years.map((year) => (
              <section class="animate space-y-4 mt-8">
                <div class="font-semibold text-black dark:text-white">
                  {year}
                </div>
                <div>
                  <ul class="not-prose flex flex-col gap-4">
                    {postsByYear[year].map((post) => (
                      <li>
                        <ArrowCard entry={{
                          id: post.id,
                          slug: post.slug,
                          collection: post.collection,
                          data: {
                            ...post.data,
                            // Ensure all required fields are present
                            body: post.body,
                            // Handle redirected posts
                            redirected: post.data.redirected || false,
                            redirectedUrl: post.data.redirectedUrl,
                            seriesPartCount: post.data.series
                              ? seriesCounts[normalizeSeriesKey(post.data.series)]
                              : undefined,
                          }
                        }} />
                      </li>
                    ))}
                  </ul>
                </div>
              </section>
            ))
          }
        </div>
      </div>
    </aside>
  </Container>
</Layout>
