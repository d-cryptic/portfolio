---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import { buildLinkGraph, findOrphans } from "@lib/content-links";
import { toContentNodeId } from "@lib/content-paths";
import { shouldIncludeDraftContent } from "@lib/content-visibility";
import { breadcrumbJsonLd, toAbsoluteUrl } from "@lib/seo";

const notes = (await getCollection("notes")).filter((entry) => shouldIncludeDraftContent(entry.data.draft));
const snippets = (await getCollection("snippets")).filter((entry) => shouldIncludeDraftContent(entry.data.draft));

const graph = buildLinkGraph([...notes, ...snippets]);
const orphanNodes = findOrphans(graph.nodes, graph.edges, "notes");
const orphanEntries = notes.filter((entry) =>
  orphanNodes.some((node) => node.id === toContentNodeId("notes", entry.id)),
);
---

<Layout
  title="Orphan Notes"
  description="Notes without inbound links"
  schema={[
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Notes", path: "/notes" },
      { name: "Orphans", path: "/notes/orphans" },
    ]),
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      name: "Orphan Notes",
      description: "Notes without inbound links",
      url: toAbsoluteUrl("/notes/orphans"),
    },
  ]}
>
  <Container>
    <section class="space-y-4">
      <h1 class="text-2xl font-semibold text-black dark:text-white">Orphan Notes</h1>
      <p class="text-sm text-black/70 dark:text-white/70">These notes currently have no backlinks from notes/snippets.</p>
      {
        orphanEntries.length > 0 ? (
          <ul class="not-prose flex flex-col gap-3">
            {orphanEntries.map((entry) => (
              <li><ArrowCard entry={entry} /></li>
            ))}
          </ul>
        ) : (
          <p class="text-sm text-black/70 dark:text-white/70">No orphan notes detected.</p>
        )
      }
    </section>
  </Container>
</Layout>
