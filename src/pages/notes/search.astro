---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { cleanContentId } from "@lib/content-paths";
import { shouldIncludeKnowledgeContent } from "@lib/content-visibility";
import { breadcrumbJsonLd, toAbsoluteUrl } from "@lib/seo";

const notes = (await getCollection("notes"))
  .filter((entry) => shouldIncludeKnowledgeContent({ draft: entry.data.draft, tags: entry.data.tags }))
  .map((entry) => ({
    title: entry.data.title,
    description: entry.data.description,
    href: `/notes/${cleanContentId(entry.id)}`,
    tags: entry.data.tags ?? [],
    updatedAt: (entry.data.updatedAt ?? entry.data.date).toISOString().slice(0, 10),
  }));

const presets = [
  { label: "recent", query: "recent" },
  { label: "seed notes", query: "seed" },
  { label: "evergreen", query: "evergreen" },
  { label: "infra", query: "infra" },
  { label: "aws", query: "aws" },
];
---

<Layout
  title="Notes Search"
  description="Saved search presets for notes"
  schema={[
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Notes", path: "/notes" },
      { name: "Search", path: "/notes/search" },
    ]),
    {
      "@context": "https://schema.org",
      "@type": "SearchResultsPage",
      name: "Notes Search",
      description: "Saved search presets for notes",
      url: toAbsoluteUrl("/notes/search"),
    },
  ]}
>
  <Container>
    <section class="space-y-4" data-pagefind-ignore>
      <h1 class="text-2xl font-semibold text-black dark:text-white">Notes Search</h1>
      <div class="flex flex-wrap gap-2 text-xs">
        {presets.map((preset) => (
          <button
            type="button"
            data-query={preset.query}
            class="rounded-sm border border-black/20 px-2 py-1 transition-colors hover:bg-black/5 dark:border-white/20 dark:hover:bg-white/5"
          >
            {preset.label}
          </button>
        ))}
      </div>
      <input
        id="notes-search-input"
        type="search"
        placeholder="Search title, description, tags"
        class="w-full rounded-md border border-black/20 bg-transparent px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-black/25 dark:border-white/20 dark:focus:ring-white/30"
      />
      <ul id="notes-search-results" class="not-prose flex flex-col gap-2"></ul>
    </section>
  </Container>
</Layout>

<script is:inline define:vars={{ notes }}>
  const input = document.getElementById("notes-search-input");
  const list = document.getElementById("notes-search-results");
  const buttons = document.querySelectorAll("[data-query]");

  const render = (query) => {
    const normalized = query.trim().toLowerCase();
    const filtered = notes.filter((note) => {
      if (!normalized) return true;
      const haystack = `${note.title} ${note.description} ${note.tags.join(" ")} ${note.updatedAt}`.toLowerCase();
      if (normalized === "recent") {
        return note.updatedAt >= new Date(Date.now() - 45 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
      }
      return haystack.includes(normalized);
    });

    list.innerHTML = filtered
      .map(
        (note) => `<li><a href="${note.href}" class="block rounded-md border border-black/15 px-3 py-2 hover:bg-black/5 dark:border-white/20 dark:hover:bg-white/5"><div class="font-semibold">${note.title}</div><div class="text-xs text-black/65 dark:text-white/65">${note.description}</div></a></li>`,
      )
      .join("");
  };

  const params = new URLSearchParams(window.location.search);
  const initial = params.get("q") ?? "";
  if (input) {
    input.value = initial;
    input.addEventListener("input", (event) => render(event.target.value));
  }

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      const query = button.getAttribute("data-query") ?? "";
      if (input) input.value = query;
      render(query);
    });
  });

  render(initial);
</script>
