---
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import ContentHeatmap from "@components/ContentHeatmap.astro";
import KnowledgeGraph from "@components/KnowledgeGraph.astro";
import { NOTES } from "@consts";
import { breadcrumbJsonLd, toAbsoluteUrl } from "@lib/seo";
import { buildLinkGraph, findOrphans } from "@lib/content-links";
import { shouldIncludeKnowledgeContent } from "@lib/content-visibility";

const notes = (await getCollection("notes"))
  .filter((post) => shouldIncludeKnowledgeContent({ draft: post.data.draft, tags: post.data.tags }))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const snippets = (await getCollection("snippets"))
  .filter((post) => shouldIncludeKnowledgeContent({ draft: post.data.draft, tags: post.data.tags }))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const groupedByYear = notes.reduce(
  (acc: Record<string, CollectionEntry<"notes">[]>, note) => {
    const year = note.data.date.getFullYear().toString();
    return {
      ...acc,
      [year]: [...(acc[year] ?? []), note],
    };
  },
  {},
);

const years = Object.keys(groupedByYear).sort((a, b) => Number(b) - Number(a));

const graph = buildLinkGraph([...notes, ...snippets]);
const noteGraphNodes = graph.nodes.filter((node) => node.collection === "notes");
const noteGraphEdges = graph.edges.filter(
  (edge) => edge.from.startsWith("notes/") || edge.to.startsWith("notes/"),
);

const orphanNotes = findOrphans(graph.nodes, graph.edges, "notes");

---

<Layout
  title={NOTES.TITLE}
  description={NOTES.DESCRIPTION}
  keywords={["notes", "digital garden", "engineering notes", "learning log"]}
  schema={[
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Notes", path: "/notes" },
    ]),
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      name: NOTES.TITLE,
      description: NOTES.DESCRIPTION,
      url: toAbsoluteUrl("/notes"),
    },
  ]}
>
  <Container>
    <aside data-pagefind-ignore class="space-y-6">
      <section class="rounded-lg border border-black/15 p-4 dark:border-white/20">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h1 class="m-0 text-xl font-semibold text-black dark:text-white">Notes</h1>
          <div class="flex flex-wrap gap-2 text-xs">
            {notes.length > 0 && (
              <a
                href="/notes/random"
                class="rounded-sm border border-black/20 px-2 py-1 transition-colors hover:bg-black/5 dark:border-white/20 dark:hover:bg-white/5"
              >
                Random note
              </a>
            )}
            <a
              href="/notes/search"
              class="rounded-sm border border-black/20 px-2 py-1 transition-colors hover:bg-black/5 dark:border-white/20 dark:hover:bg-white/5"
            >
              Saved searches
            </a>
            <a
              href="/notes/orphans"
              class="rounded-sm border border-black/20 px-2 py-1 transition-colors hover:bg-black/5 dark:border-white/20 dark:hover:bg-white/5"
            >
              Orphans ({orphanNotes.length})
            </a>
          </div>
        </div>
        <p class="mt-2 mb-0 text-sm text-black/70 dark:text-white/70">GitBook-style list, with backlinks, graph, and lightweight garden tooling.</p>
      </section>

      <ContentHeatmap entries={notes.map((note) => ({ date: note.data.updatedAt ?? note.data.date }))} title="Notes Update Heatmap" />

      <KnowledgeGraph title="Notes Graph" nodes={noteGraphNodes} edges={noteGraphEdges} />

      <div class="space-y-8">
        {years.map((year) => (
          <section class="animate space-y-3">
            <div class="text-sm font-semibold uppercase tracking-wide text-black/60 dark:text-white/60">{year}</div>
            <ul class="not-prose flex flex-col gap-3">
              {groupedByYear[year].map((note) => (
                <li>
                  <ArrowCard entry={note} />
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </aside>
  </Container>
</Layout>
