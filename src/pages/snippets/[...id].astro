---
import { existsSync } from "node:fs";
import path from "node:path";
import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import BackToPrevious from "@components/BackToPrevious.astro";
import PostNavigation from "@components/PostNavigation.astro";
import TableOfContents from "@components/TableOfContents.astro";
import KnowledgeGraph from "@components/KnowledgeGraph.astro";
import Giscus from "@components/Giscus.astro";
import { SITE } from "@consts";
import { breadcrumbJsonLd, toAbsoluteUrl } from "@lib/seo";
import { getGitLastModified } from "@lib/git-last-modified";
import { buildBacklinks, buildLinkGraph, getRelatedByTags } from "@lib/content-links";
import { cleanContentId, toContentNodeId, toContentPath } from "@lib/content-paths";
import { shouldIncludeDraftContent } from "@lib/content-visibility";
import { readingTime, wordCount } from "@lib/utils";

const MATURITY_STYLES: Record<string, string> = {
  seed: "border-yellow-600/30 bg-yellow-500/10 text-yellow-900 dark:text-yellow-200",
  growing: "border-blue-600/30 bg-blue-500/10 text-blue-900 dark:text-blue-200",
  evergreen: "border-green-600/30 bg-green-500/10 text-green-900 dark:text-green-200",
  archived: "border-black/25 bg-black/5 text-black/80 dark:border-white/30 dark:bg-white/10 dark:text-white/80",
};

const getContentFilePath = (collection: "notes" | "snippets", id: string): string | null => {
  const candidates = [
    path.join(process.cwd(), "src", "content", collection, `${id}.md`),
    path.join(process.cwd(), "src", "content", collection, `${id}.mdx`),
    path.join(process.cwd(), "src", "content", collection, id, "index.md"),
    path.join(process.cwd(), "src", "content", collection, id, "index.mdx"),
  ];

  const matched = candidates.find((candidate) => existsSync(candidate));
  return matched ?? null;
};

export async function getStaticPaths() {
  const snippets = (await getCollection("snippets"))
    .filter((snippet) => shouldIncludeDraftContent(snippet.data.draft))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return snippets.map((snippet) => ({ params: { id: cleanContentId(snippet.id) }, props: snippet }));
}

type Props = CollectionEntry<"snippets">;

const notes = (await getCollection("notes"))
  .filter((entry) => shouldIncludeDraftContent(entry.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const snippets = (await getCollection("snippets"))
  .filter((entry) => shouldIncludeDraftContent(entry.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const snippet = Astro.props as Props;
const snippetIndex = snippets.findIndex((entry) => cleanContentId(entry.id) === cleanContentId(snippet.id));
const nextSnippet = snippetIndex >= 0 ? snippets[snippetIndex + 1] : undefined;
const prevSnippet = snippetIndex > 0 ? snippets[snippetIndex - 1] : undefined;

const { Content, headings } = await render(snippet);
const snippetPath = toContentPath("snippets", snippet.id);
const snippetUrl = toAbsoluteUrl(snippetPath);

const graph = buildLinkGraph([...notes, ...snippets]);
const currentNodeId = toContentNodeId("snippets", snippet.id);
const currentNode = graph.nodes.find((node) => node.id === currentNodeId);
const backlinks = buildBacklinks(currentNodeId, graph.nodes, graph.edges);
const relatedByTags = currentNode ? getRelatedByTags(currentNode, graph.nodes, 4) : [];

const manualRelatedNotes = (snippet.data.relatedNotes ?? [])
  .map((id) => notes.find((entry) => entry.id === id))
  .filter((entry): entry is CollectionEntry<"notes"> => Boolean(entry));

const manualRelatedSnippets = (snippet.data.relatedSnippets ?? [])
  .map((id) => snippets.find((entry) => entry.id === id))
  .filter((entry): entry is CollectionEntry<"snippets"> => Boolean(entry));

const relatedNodes = relatedByTags.filter((entry) => entry.id !== currentNodeId);
const localNodeIds = new Set([currentNodeId, ...backlinks.map((entry) => entry.id), ...relatedNodes.map((entry) => entry.id)]);
const localNodes = graph.nodes.filter((entry) => localNodeIds.has(entry.id));
const localEdges = graph.edges.filter((edge) => localNodeIds.has(edge.from) && localNodeIds.has(edge.to));

const previewMap = graph.nodes.reduce(
  (acc, node) => ({
    ...acc,
    [node.href]: {
      title: node.title,
      description: node.description,
      tags: node.tags,
    },
  }),
  {} as Record<string, { title: string; description: string; tags: string[] }>,
);

const contentFilePath = getContentFilePath("snippets", snippet.id);
const gitLastModified = contentFilePath ? getGitLastModified(contentFilePath) : null;
const lastModified = gitLastModified ?? snippet.data.updatedAt ?? snippet.data.date;
const totalWords = snippet.body ? wordCount(snippet.body) : 0;
const maturity = snippet.data.maturity ?? "growing";
const maturityClass = MATURITY_STYLES[maturity] ?? MATURITY_STYLES.growing;
---

<Layout
  title={snippet.data.title}
  description={snippet.data.description}
  ogType="article"
  publishedTime={snippet.data.date}
  modifiedTime={lastModified}
  keywords={snippet.data.tags || ["snippets", "code"]}
  schema={[
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Snippets", path: "/snippets" },
      { name: snippet.data.title, path: snippetPath },
    ]),
    {
      "@context": "https://schema.org",
      "@type": "TechArticle",
      headline: snippet.data.title,
      description: snippet.data.description,
      datePublished: snippet.data.date,
      dateModified: lastModified,
      author: {
        "@type": "Person",
        name: SITE.AUTHOR,
      },
      mainEntityOfPage: snippetUrl,
      url: snippetUrl,
      inLanguage: "en",
    },
  ]}
>
  <Container>
    <div class="animate">
      <BackToPrevious href="/snippets">Back to snippets</BackToPrevious>
    </div>

    <section class="my-8 space-y-3" data-pagefind-ignore>
      <div class="flex flex-wrap items-center gap-2 text-sm">
        <FormattedDate date={snippet.data.date} />
        <span>&bull;</span>
        <span>{readingTime(snippet.body)}</span>
        <span>&bull;</span>
        <span>{totalWords} words</span>
        <span>&bull;</span>
        <span>Updated <FormattedDate date={lastModified} /></span>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <span class={`rounded-full border px-2 py-1 text-xs font-medium ${maturityClass}`}>
          {maturity}
        </span>
        <span class="rounded-full border border-black/20 px-2 py-1 text-xs dark:border-white/20">
          {snippet.data.language ?? "text"}
        </span>
        <a
          href={`/snippets/source/${cleanContentId(snippet.id)}.txt`}
          class="inline-flex items-center gap-1.5 rounded-sm border border-black/20 px-2 py-1 text-xs transition-colors hover:bg-black/5 dark:border-white/20 dark:hover:bg-white/5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 shrink-0 fill-none stroke-current stroke-2">
            <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 3 14 8 19 8"></polyline>
            <line x1="9" y1="13" x2="15" y2="13"></line>
            <line x1="9" y1="17" x2="15" y2="17"></line>
          </svg>
          Export Markdown
        </a>
        <button
          id="print-content-button"
          type="button"
          class="inline-flex items-center gap-1.5 rounded-sm border border-black/20 px-2 py-1 text-xs transition-colors hover:bg-black/5 dark:border-white/20 dark:hover:bg-white/5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 shrink-0 fill-none stroke-current stroke-2">
            <polyline points="6 9 6 2 18 2 18 9"></polyline>
            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
            <rect x="6" y="14" width="12" height="8"></rect>
          </svg>
          Export PDF
        </button>
        {
          snippet.data.runnerUrl ? (
            <a
              href={snippet.data.runnerUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-sm border border-black/20 px-2 py-1 text-xs transition-colors hover:bg-black/5 dark:border-white/20 dark:hover:bg-white/5"
            >
              Open Runner
            </a>
          ) : null
        }
      </div>

      <h1 class="animate text-3xl font-semibold text-black dark:text-white">{snippet.data.title}</h1>

      {
        snippet.data.tags && snippet.data.tags.length > 0 ? (
          <div class="animate flex flex-wrap gap-2 pt-1">
            {snippet.data.tags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class="rounded-sm border border-black/15 px-2 py-1 text-sm whitespace-normal break-words transition-colors duration-300 ease-in-out hover:bg-black/5 hover:text-black focus-visible:bg-black/5 focus-visible:text-black dark:border-white/20 dark:hover:bg-white/5 dark:hover:text-white dark:focus-visible:bg-white/5 dark:focus-visible:text-white"
              >
                {tag}
              </a>
            ))}
          </div>
        ) : null
      }
    </section>

    <article class="animate" id="content-article">
      {headings.length > 0 && <TableOfContents headings={headings} />}

      <div class="mt-6" data-md-content>
        <Content />
      </div>

        {
          backlinks.length > 0 ? (
            <section class="mt-12 rounded-lg border border-black/15 p-4 dark:border-white/20" data-pagefind-ignore>
              <h2 class="m-0 text-lg font-semibold">Backlinks</h2>
              <ul class="mt-3 space-y-2">
                {backlinks.map((entry) => (
                  <li>
                    <a href={entry.href} class="font-medium underline-offset-2 hover:underline">{entry.title}</a>
                    <p class="m-0 text-sm text-black/70 dark:text-white/70">{entry.description}</p>
                  </li>
                ))}
              </ul>
            </section>
          ) : null
        }

        {
          relatedNodes.length > 0 || manualRelatedNotes.length > 0 || manualRelatedSnippets.length > 0 ? (
            <section class="mt-12 rounded-lg border border-black/15 p-4 dark:border-white/20" data-pagefind-ignore>
              <h2 class="m-0 text-lg font-semibold">Related</h2>
              <div class="mt-3 grid gap-4 md:grid-cols-2">
                <div>
                  <h3 class="m-0 text-sm font-semibold uppercase tracking-wide text-black/60 dark:text-white/60">Auto</h3>
                  <ul class="mt-2 space-y-2 text-sm">
                    {relatedNodes.map((entry) => (
                      <li><a href={entry.href}>{entry.title}</a></li>
                    ))}
                  </ul>
                </div>
                <div>
                  <h3 class="m-0 text-sm font-semibold uppercase tracking-wide text-black/60 dark:text-white/60">Manual</h3>
                  <ul class="mt-2 space-y-2 text-sm">
                    {manualRelatedNotes.map((entry) => (
                      <li><a href={toContentPath("notes", entry.id)}>Note: {entry.data.title}</a></li>
                    ))}
                    {manualRelatedSnippets.map((entry) => (
                      <li><a href={toContentPath("snippets", entry.id)}>Snippet: {entry.data.title}</a></li>
                    ))}
                  </ul>
                </div>
              </div>
            </section>
          ) : null
        }

        <div class="mt-12" data-pagefind-ignore>
          <KnowledgeGraph title="Local Graph" nodes={localNodes} edges={localEdges} currentNodeId={currentNodeId} />
        </div>

        <div class="mt-16" data-pagefind-ignore>
          <PostNavigation prevPost={prevSnippet} nextPost={nextSnippet} path="snippets" />
        </div>

        <div class="mt-16" data-pagefind-ignore>
          <Giscus />
        </div>
      </article>
  </Container>

  <script is:inline define:vars={{ previewMap }}>
    window.__CONTENT_PREVIEW_MAP__ = previewMap;
  </script>
  <script type="module" src="/utils/content-enhancements.js"></script>
</Layout>
