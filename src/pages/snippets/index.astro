---
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import ContentHeatmap from "@components/ContentHeatmap.astro";
import KnowledgeGraph from "@components/KnowledgeGraph.astro";
import { SNIPPETS } from "@consts";
import { breadcrumbJsonLd, toAbsoluteUrl } from "@lib/seo";
import { buildLinkGraph, findOrphans } from "@lib/content-links";
import { shouldIncludeKnowledgeContent } from "@lib/content-visibility";

const snippets = (await getCollection("snippets"))
  .filter((post) => shouldIncludeKnowledgeContent({ draft: post.data.draft, tags: post.data.tags }))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const notes = (await getCollection("notes"))
  .filter((post) => shouldIncludeKnowledgeContent({ draft: post.data.draft, tags: post.data.tags }))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const groupedByYear = snippets.reduce(
  (acc: Record<string, CollectionEntry<"snippets">[]>, snippet) => {
    const year = snippet.data.date.getFullYear().toString();
    return {
      ...acc,
      [year]: [...(acc[year] ?? []), snippet],
    };
  },
  {},
);

const years = Object.keys(groupedByYear).sort((a, b) => Number(b) - Number(a));

const graph = buildLinkGraph([...notes, ...snippets]);
const snippetGraphNodes = graph.nodes.filter((node) => node.collection === "snippets");
const snippetGraphEdges = graph.edges.filter(
  (edge) => edge.from.startsWith("snippets/") || edge.to.startsWith("snippets/"),
);

const orphanSnippets = findOrphans(graph.nodes, graph.edges, "snippets");

---

<Layout
  title={SNIPPETS.TITLE}
  description={SNIPPETS.DESCRIPTION}
  keywords={["code snippets", "developer snippets", "shell", "devops snippets"]}
  schema={[
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Snippets", path: "/snippets" },
    ]),
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      name: SNIPPETS.TITLE,
      description: SNIPPETS.DESCRIPTION,
      url: toAbsoluteUrl("/snippets"),
    },
  ]}
>
  <Container>
    <aside data-pagefind-ignore class="space-y-6">
      <section class="rounded-lg border border-black/15 p-4 dark:border-white/20">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h1 class="m-0 text-xl font-semibold text-black dark:text-white">Snippets</h1>
          <div class="flex flex-wrap gap-2 text-xs">
            {snippets.length > 0 && (
              <a
                href="/snippets/random"
                class="rounded-sm border border-black/20 px-2 py-1 transition-colors hover:bg-black/5 dark:border-white/20 dark:hover:bg-white/5"
              >
                Random snippet
              </a>
            )}
            <a
              href="/snippets/search"
              class="rounded-sm border border-black/20 px-2 py-1 transition-colors hover:bg-black/5 dark:border-white/20 dark:hover:bg-white/5"
            >
              Saved searches
            </a>
            <a
              href="/snippets/orphans"
              class="rounded-sm border border-black/20 px-2 py-1 transition-colors hover:bg-black/5 dark:border-white/20 dark:hover:bg-white/5"
            >
              Orphans ({orphanSnippets.length})
            </a>
          </div>
        </div>
        <p class="mt-2 mb-0 text-sm text-black/70 dark:text-white/70">Compact snippet index with language tags, graph links, and quick actions.</p>
      </section>

      <ContentHeatmap entries={snippets.map((snippet) => ({ date: snippet.data.updatedAt ?? snippet.data.date }))} title="Snippets Update Heatmap" />

      <KnowledgeGraph title="Snippets Graph" nodes={snippetGraphNodes} edges={snippetGraphEdges} />

      <div class="space-y-8">
        {years.map((year) => (
          <section class="animate space-y-3">
            <div class="text-sm font-semibold uppercase tracking-wide text-black/60 dark:text-white/60">{year}</div>
            <ul class="not-prose flex flex-col gap-3">
              {groupedByYear[year].map((snippet) => (
                <li>
                  <ArrowCard entry={snippet} />
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </aside>
  </Container>
</Layout>
